{
  "name": "fireclanker",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "fireclanker": "dist/fireclanker"
  },
  "type": "module",
  "scripts": {
    "build": "bun run build:production",
    "build:production": "bun build src/main.ts --compile --minify --define FIRECLANKER_COMPOSITION='\"production\"' --outfile dist/fireclanker",
    "build:test": "bun build src/main.ts --compile --define FIRECLANKER_COMPOSITION='\"test\"' --outfile dist/fireclanker-test",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-iam": "3.1087.0",
    "@aws-sdk/client-lambda": "3.1087.0",
    "@aws-sdk/client-s3": "3.1087.0",
    "@aws-sdk/client-secrets-manager": "3.1087.0",
    "@aws-sdk/client-sts": "3.1087.0",
    "@effect/platform-bun": "4.0.0-beta.98",
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/platform-node-shared": "4.0.0-beta.98",
    "alchemy": "2.0.0-beta.62",
    "effect": "4.0.0-beta.98"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
